# ─────────────────────────────────────────────────────────────────────────────
# TI Investigation Platform — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it's in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Backend only — never expose to frontend

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
# Frontend origins allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── External APIs (Wave 1+) ───────────────────────────────────────────────────
# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your-vt-key-here

# AbuseIPDB: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your-abuseipdb-key-here

# WhoisXML: https://user.whoisxmlapi.com/products
WHOISXML_API_KEY=your-whoisxml-key-here

# ── Frontend (Vite — must start with VITE_) ───────────────────────────────────
# Backend API URL — used by the React app to call the FastAPI server
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
